# Backend — copia este archivo a .env y rellena los valores.

# Conexión a Postgres (con extensión pgvector). En Railway, referencia la
# variable del servicio Postgres (DATABASE_URL).
DATABASE_URL=postgresql://usuario:password@host:puerto/basededatos

# Pon "true" solo si tu Postgres exige SSL. Railway no lo necesita.
DATABASE_SSL=false

# API key de Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Cadena de modelos con fallback (opcional). Si el primero se agota (429) o se
# satura (503), se pasa al siguiente. Por defecto:
# gemini-3.5-flash,gemini-3-flash-preview,gemini-2.5-flash
# GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-flash

# Puerto (en Railway se inyecta automáticamente)
PORT=3000

NODE_ENV=development

# Origen permitido por CORS. En producción, la URL del frontend en Vercel.
FRONTEND_URL=http://localhost:5173
